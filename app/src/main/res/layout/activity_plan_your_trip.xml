<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <!-- Title at top -->
    <TextView
        android:id="@+id/textTripTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🛫 Plan Your Trip"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#1976D2"
        android:padding="20dp"
        android:gravity="center"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- RecyclerView fills most space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTripPlan"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/textTripTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutInputSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Input Section (Start Location + Suggest + Maps) -->
    <LinearLayout
        android:id="@+id/layoutInputSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="12dp"
        android:elevation="4dp"
        android:layout_margin="10dp"
        app:layout_constraintBottom_toTopOf="@id/layoutButtonBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚩 Start From:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editStartingLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingHorizontal="10dp"
            android:backgroundTint="#BBBBBB"
            android:textColor="#37474F"
            android:textColorHint="#90A4AE"
            android:inputType="textCapWords"
            android:background="@android:drawable/edit_text"
            android:textSize="14sp"
            android:hint="Enter your starting location"/>

        <Button
            android:id="@+id/btnSuggestRoute"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🚘 Suggest Route"
            android:layout_marginTop="10dp"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnOpenInMaps"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📍 Open in Google Maps"
            android:layout_marginTop="8dp"
            android:backgroundTint="#0288D1"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom Button Bar (icon-only) -->
    <LinearLayout
        android:id="@+id/layoutButtonBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center">

        <!-- Save Plan Button -->
        <ImageButton
            android:id="@+id/btnSavePlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_save"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save Plan"
            app:tint="#FF9800"
            android:padding="12dp"/>

        <!-- View Saved Trips Button -->
        <ImageButton
            android:id="@+id/btnViewSavedTrips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_folder"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="View Saved Trips"
            app:tint="#009688"
            android:padding="12dp"/>

        <!-- Clear All Button -->
        <ImageButton
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear All"
            app:tint="#D32F2F"
            android:padding="12dp"/>

        <!-- Add More Places Button -->
        <ImageButton
            android:id="@+id/btnAddPlace"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add More Places"
            app:tint="#009688"
            android:padding="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
